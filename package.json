{
  "name": "ad-takedown-api",
  "version": "1.0.0",
  "description": "Webhook-driven ad violation takedown queue with BullMQ",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "worker": "ts-node-dev --respawn --transpile-only src/workers/takedown.worker.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run worker\""
  },
  "dependencies": {
    "bullmq": "^5.8.0",
    "express": "^4.18.3",
    "ioredis": "^5.3.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "concurrently": "^8.2.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
